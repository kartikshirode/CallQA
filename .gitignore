# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.venv/
venv/
env/

# Secrets: never commit tokens or keys
.env
*.env
secrets/

# Audio and model artifacts (regenerated, not versioned)
data/synthetic/**/*.wav
data/synthetic/**/*.flac

# HarperValley raw corpus and derived audio: refetchable, gold lives in the
# registry, so keep the bytes out of git. The subset manifest stays tracked.
data/harpervalley/raw/
data/harpervalley/audio/

# Cached Whisper transcripts from the Week 2 sweep: rebuildable from the audio,
# keyed by model and call, so keep them out of git.
data/asr/

*.ckpt
*.pt

# OS / editor
.DS_Store
.idea/
.vscode/
.swarm-audit/
